# Copy to .env and fill in. NEVER commit .env (gitignored).
ANTHROPIC_API_KEY=
HEVY_API_KEY=

# Optional overrides (defaults in app/config.py)
ANTHROPIC_MODEL=claude-opus-4-8
TOP_K=8
# Host bind: 127.0.0.1 by default; set to the Unraid box's tailnet IP to reach
# it over Tailscale (never 0.0.0.0 on a public interface).
BIND_IP=127.0.0.1
PORT=8000
