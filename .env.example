# Copy to .env and fill in. NEVER commit .env (gitignored).
ANTHROPIC_API_KEY=
HEVY_API_KEY=

# LLM backend: "ollama" (default, free, local GPU over Tailscale) or "anthropic"
# (hosted, billed separately from Claude Pro).
LLM_BACKEND=ollama
OLLAMA_BASE_URL=   # e.g. http://100.85.238.56:11434 (tailnet IP of the GPU box)
OLLAMA_MODEL=qwen2.5:14b

# Optional overrides (defaults in app/config.py)
ANTHROPIC_MODEL=claude-opus-4-8
TOP_K=8
# Host bind: 127.0.0.1 by default; set to the Unraid box's tailnet IP to reach
# it over Tailscale (never 0.0.0.0 on a public interface).
BIND_IP=127.0.0.1
PORT=8000
